# EAS Build archive exclusions
# Only the frontend/ source code is needed — EAS installs dependencies itself.

# node_modules — never send these, EAS runs npm/yarn install on its servers
node_modules/
frontend/node_modules/
backend/node_modules/
admin-dashboard/node_modules/

# Git history — not needed for building
.git/

# Backend API server
backend/

# React/Vite admin dashboard
admin-dashboard/

# Replit agent local data
.local/

# IDE and tool caches
.cache/
.config/

# Root-level files not needed by Expo
.snyk
replit.md
attached_assets/
screenshots/
