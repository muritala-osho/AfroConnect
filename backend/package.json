{
  "name": "afroconnect-backend",
  "version": "1.0.0",
  "description": "AfroConnect Dating App Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "snyk:test": "snyk test --severity-threshold=high",
    "snyk:monitor": "snyk monitor",
    "snyk:fix": "snyk fix",
    "security": "snyk test --severity-threshold=medium --json > snyk-report.json || true"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "testTimeout": 10000
  },
  "keywords": [
    "dating",
    "api",
    "mongodb",
    "express"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@react-native-community/slider": "^5.0.1",
    "@sendgrid/mail": "^8.1.6",
    "agora-access-token": "^2.0.4",
    "agora-rtc-sdk-ng": "^4.24.1",
    "agora-token": "^2.0.5",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.8.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "expo-notifications": "~0.32.13",
    "expo-server-sdk": "^4.0.0",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "8.2.2",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "http-proxy": "^1.18.1",
    "ioredis": "^5.10.1",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.18.0",
    "mongoose": "^8.21.0",
    "multer": "2.1.1",
    "nodemailer": "^8.0.4",
    "openai": "^6.15.0",
    "react-native-agora": "^4.5.3",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "snyk": "^1.1303.2",
    "supertest": "^7.1.4"
  },
  "overrides": {
    "@xmldom/xmldom": "0.8.12"
  }
}
